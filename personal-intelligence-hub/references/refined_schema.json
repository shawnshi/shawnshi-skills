{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "punchline",
    "insights",
    "digest",
    "market",
    "action_levers",
    "top_10"
  ],
  "properties": {
    "punchline": {
      "type": "string",
      "description": "高度概括的一句话核心判断"
    },
    "insights": {
      "type": "string",
      "description": "多维度的核心洞察，使用 markdown 格式"
    },
    "digest": {
      "type": "string",
      "description": "本期情报的总体总结"
    },
    "market": {
      "type": "string",
      "description": "市场动态与信号监控"
    },
    "action_levers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain", "task"],
        "properties": {
          "domain": { "type": "string" },
          "task": { "type": "string" }
        }
      }
    },
    "top_10": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title", "url", "source", "date", "strategic_score",
          "summary_zh", "reason", "fact", "connection",
          "deduction", "actionability", "confidence", "intelligence_level"
        ],
        "properties": {
          "title": { "type": "string" },
          "title_zh": { "type": "string" },
          "url": { "type": "string" },
          "source": { "type": "string" },
          "date": { "type": "string" },
          "strategic_score": { "type": "number" },
          "summary_zh": { "type": "string" },
          "reason": { "type": "string" },
          "fact": { "type": "string" },
          "connection": { "type": "string" },
          "deduction": { "type": "string" },
          "actionability": { "type": "string" },
          "confidence": { "type": "string" },
          "intelligence_level": { "type": "string" },
          "intel_grade": { "type": "string" }
        }
      }
    }
  }
}
